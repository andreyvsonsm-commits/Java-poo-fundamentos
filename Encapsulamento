
class Pessoa {

    private String nome;
    private int idade;

    Pessoa(String nome, int idade) {
        this.nome = nome;
        this.idade = idade;
    }

    String getNome() {
        return nome;
    }

    void setNome(String nome) {
        this.nome = nome;
    }

    int getIdade() {
        return idade;
    }

    void setIdade(int idade) {
        this.idade = idade;
    }
}

public class Main {
    public static void main(String[] args) {

        Pessoa p1 = new Pessoa("Andreyvson", 19);

        System.out.println(p1.getNome());

        p1.setIdade(20);

        System.out.println(p1.getIdade());
    }
}
