
class Funcionario {

    void trabalhar() {
        System.out.println("Funcionário trabalhando.");
    }
}

class Programador extends Funcionario {

    @Override
    void trabalhar() {
        System.out.println("Programando em Java.");
    }
}

class Designer extends Funcionario {

    @Override
    void trabalhar() {
        System.out.println("Criando anúncios.");
    }
}

public class Main {
    public static void main(String[] args) {

        Funcionario f1 = new Programador();
        Funcionario f2 = new Designer();

        f1.trabalhar();
        f2.trabalhar();
    }
}
